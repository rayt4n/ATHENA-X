# ============================================================================
# ATHENA-X .gitignore — Python + Node.js + Next.js + TypeScript + Bun
# ============================================================================

# ─── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
*.egg
*.egg-info/
.eggs/
sdist/
wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Type checking
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ─── Node.js ───────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/
.nyc_output/
*.lcov

# Build outputs
build/
dist/
out/
.next/
.turbo/
.vercel/

# ─── Next.js ────────────────────────────────────────────────────────────────
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# ─── TypeScript ─────────────────────────────────────────────────────────────
*.tsbuildinfo
*.js.map

# ─── Bun ────────────────────────────────────────────────────────────────────
bun.lockb
.bun/
# Note: bun.lock (text lockfile) IS committed for reproducible installs

# ─── Environment & Secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx

# ─── IDE / Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
server.log
dev.log
dev.out.log
dev.pid

# ─── OS / Misc ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.eslintcache
.cache/
tmp/
temp/

# ─── ATHENA-X specific ──────────────────────────────────────────────────────
# Skills directory (tooling, not project content)
/skills/

# Internal Z.ai scripts
/.zscripts/

# Local-only artifacts
local-*
.claude
.z-ai-config
prompt
test
tool-results/
upload/
db/
